:root {
  /* ----- 蓝粉主题变量 ----- */
  --primary-blue: #aee4ff;
  --primary-pink: #ffccd5;
  --pink-soft: #ffe3e8;
  --blue-soft: #d9f0ff;
  
  --bg-page: #FFFFFF;
  --bg-card: #FFFFFF;
  --bg-card-solid: #FFFFFF;
  --bg-card-solid-2: #FFFFFF;
  --bg-card-hover: rgba(0, 0, 0, 0.03);
  --bg-card-strong: rgba(0, 0, 0, 0.06);
  --bg-current: #000000;
  --bg-accent: #f5faff;
  --bg-input: rgba(255, 255, 255, 0.9);
  --bg-input-focus: rgba(255, 255, 255, 1);
  --bg-modal: #FFFFFF;
  --bg-modal-2: #FFFFFF;
  --bg-stat: rgba(255, 255, 255, 0.9);
  --bg-tooltip: rgba(0, 0, 0, 0.85);
  --bg-track: rgba(255, 255, 255, 0.8);
  --bg-card-light: rgba(255, 255, 255, 0.6);
  --bg-card-2: rgba(255, 255, 255, 0.65);
  --bg-card-3: rgba(255, 255, 255, 0.72);
  --bg-card-4: rgba(255, 255, 255, 0.85);
  --bg-card-tint: rgba(174, 228, 255, 0.12);
  --bg-footer-hover: rgba(174, 228, 255, 0.2);
  --border-bright: rgba(0, 0, 0, 0.08);
  --border-soft: rgba(0, 0, 0, 0.05);
  --border-card: #ffccd5;
  --text-main: #2c2c2c;
  --text-strong: #1a1a1a;
  --text-link: #e695b0;
  --text-visited: #b0a0b5;
  --text-on-dark: #FFFFFF;
  --text-placeholder: rgba(0, 0, 0, 0.3);
  --link-underline: #ffa5c0;
  --bar-fill-light: #ffd9e2;
  --bar-fill-mid: #ffb3c6;
  --bar-fill-dark: #ff8fac;
  --brown-mid: #d47a9e;
  --shadow-color-1: rgba(0, 0, 0, 0.04);
  --shadow-color-2: rgba(0, 0, 0, 0.06);
  --shadow-color-3: rgba(0, 0, 0, 0.08);
  --shadow-color-4: rgba(0, 0, 0, 0.10);
  --shadow-color-5: rgba(0, 0, 0, 0.15);
  --shadow-color-6: rgba(0, 0, 0, 0.25);
  --shadow-warm-1: rgba(174, 228, 255, 0.15);
  --shadow-warm-2: rgba(255, 204, 213, 0.2);
  --shadow-warm-3: rgba(174, 228, 255, 0.25);
  --border-warm-1: rgba(255, 204, 213, 0.12);
  --border-warm-2: rgba(174, 228, 255, 0.15);
  --border-warm-3: rgba(255, 204, 213, 0.2);
  --border-warm-4: rgba(0, 0, 0, 0.08);
  --border-warm-5: rgba(0, 0, 0, 0.12);
  --border-warm-6: rgba(0, 0, 0, 0.15);
  --border-warm-7: rgba(0, 0, 0, 0.18);
  --border-warm-8: rgba(0, 0, 0, 0.22);
  --border-warm-9: rgba(0, 0, 0, 0.28);
  --border-warm-10: rgba(0, 0, 0, 0.4);
  --shadow-pink-1: rgba(255, 204, 213, 0.08);
  --shadow-pink-2: rgba(255, 204, 213, 0.12);
  --shadow-pink-3: rgba(174, 228, 255, 0.15);
  --shadow-pink-4: rgba(255, 204, 213, 0.18);
  --shadow-pink-5: rgba(174, 228, 255, 0.25);
  --icon-tint-main: brightness(0.2) sepia(1) hue-rotate(-10deg) saturate(2);
}

:root {
  --radius-card: 20px;
  --radius-button: 10px;
  --radius-pill: 9999px;
  --max-width-list: 53rem;
  --max-width-work: 1000px;
}

/* ===== 全局背景 ===== */
html, body, #outer, #inner, #main, #dashboard, #header, #header .heading {
  background-color: var(--bg-page) !important;
}

/* 优雅选中 */
::selection {
  background: rgba(174, 228, 255, 0.35) !important;
  color: #2c2c2c !important;
}
::-moz-selection {
  background: rgba(174, 228, 255, 0.35) !important;
  color: #2c2c2c !important;
}

/* ===== 链接 & 文本 ===== */
#main a {
  color: var(--text-main);
  transition: color 0.2s, text-shadow 0.2s;
}
#main a:hover {
  color: var(--text-link) !important;
  text-shadow: 0 0 4px rgba(255, 204, 213, 0.4);
}

/* ===== 头部图标 ===== */
#header #greeting .dropdown > a[href*="/works/new"],
#header #greeting .dropdown > a[href*="/users/"],
#header #greeting a[href*="/users/logout"] {
  display: inline-block !important;
  width: 22px !important;
  height: 22px !important;
  padding: 0 !important;
  background-repeat: no-repeat !important;
  background-position: center !important;
  background-size: contain !important;
  background-color: transparent !important;
  color: transparent !important;
  font-size: 0 !important;
  line-height: 0 !important;
  text-indent: -9999px !important;
  overflow: hidden !important;
  border: none !important;
  box-shadow: none !important;
}
#header #greeting .dropdown > a[href*="/works/new"] {
  background-image: url("https://github.com/Ambra1720/lumu/blob/icon/Write.png") !important;
}
#header #greeting .dropdown > a[href*="/users/"] {
  background-image: url("https://github.com/Ambra1720/lumu/blob/icon/Profile.png") !important;
}
#header #greeting a[href*="/users/logout"] {
  background-image: url("https://github.com/Ambra1720/lumu/blob/icon/Logout.png") !important;
}

/* ===== Logo 大图 ===== */
#header h1.heading a {
  display: block !important;
  margin: 0 auto !important;
  background-image: url("https://github.com/Ambra1720/lumu/blob/icon/LOGO.png") !important;
  background-repeat: no-repeat !important;
  background-position: center bottom !important;
  background-size: contain !important;
  height: 160px !important;
  width: 100% !important;
  color: transparent !important;
  border: none !important;
}

/* ===== 页脚装饰 ===== */
#footer::before {
  content: "🐶⋆ ｡:ﾟ･*☽:ﾟ･⋆ ｡✰⋆ ｡:ﾟ･*☽:ﾟ･⋆ ｡✰⋆ ｡:ﾟ･*🐱";
  display: block;
  text-align: center;
  font-size: 1.2rem;
  letter-spacing: 4px;
  margin-bottom: 12px;
  opacity: 0.8;
  color: var(--primary-pink);
}

/* ===== 卡片边框 & 阴影 ===== */
.news.index.group li.post.group,
li.work.blurb,
li.bookmark.blurb,
li.series.blurb,
li.mystery.blurb,
ol.collection.index li.collection.blurb.group,
.collection li.bookmark,
.user.home .index li.blurb {
  border: 1.5px solid var(--border-card) !important;
  border-radius: 20px !important;
  box-shadow: 0px 10px 25px var(--shadow-color-2), 0 0 0 1px rgba(255,204,213,0.15) !important;
}

/* ===== 按钮 & 动作 ===== */
.actions a,
.action,
.actions button,
input[type="submit"],
button {
  background: var(--bg-card) !important;
  border: 1px solid var(--primary-pink) !important;
  border-radius: 30px !important;
  box-shadow: 0 2px 6px var(--shadow-pink-2) !important;
  color: var(--text-main) !important;
  transition: all 0.2s ease;
}
.actions a:hover,
.actions button:hover,
input[type="submit"]:hover {
  background: var(--primary-pink) !important;
  color: #2c2c2c !important;
  transform: translateY(-1px);
  box-shadow: 0 6px 12px rgba(255,204,213,0.3) !important;
}

/* ===== Kudo 提示 ===== */
#kudos_message.notice::before {
  content: "🐶 Magic has been cast! Thank you for your love.🐱" !important;
  font-size: 14pt !important;
  color: var(--text-main) !important;
  font-family: "Georgia", serif;
  font-weight: bold;
}
#kudos_message.kudos_error::before {
  content: "🐶 You have already cast this spell! (Kudos already left) 🐱" !important;
  font-size: 14pt !important;
  color: var(--text-main) !important;
}

/* ===== 头部装饰线条 ===== */
#header::after {
  content: "♡︎★︎♡ﾟ︎･*:.｡ ｡.:*･ﾟ♡︎★︎♡ﾟ︎･*:.｡ ｡.:*♡︎★︎♡ﾟ" !important;
  display: block !important;
  text-align: center;
  font-size: 1.3rem;
  letter-spacing: 6px;
  margin-top: 6px;
  margin-bottom: 12px;
  color: var(--primary-pink);
}

/* ===== 统计图标 ===== */
dl.stats dd:nth-of-type(1)::before {
  background: url("https://github.com/Ambra1720/lumu/blob/icon/comments.png") no-repeat center;
  background-size: contain;
}
dl.stats dd:nth-of-type(2)::before {
  background: url("https://github.com/Ambra1720/lumu/blob/icon/kudos.png") no-repeat center;
  background-size: contain;
}
dl.stats dd.kudos::before {
  background: url("https://github.com/Ambra1720/lumu/blob/icon/kudos.png") no-repeat center;
  background-size: contain;
}
dl.stats dd.words::before {
  background: url("https://github.com/Ambra1720/lumu/blob/icon/words.png") no-repeat center;
  background-size: contain;
}
dl.stats dd.chapters::before {
  background: url("https://github.com/Ambra1720/lumu/blob/icon/chapters.png") no-repeat center;
  background-size: contain;
}
dl.stats dd.bookmarks::before {
  background: url("https://github.com/Ambra1720/lumu/blob/icon/bookmark.png") no-repeat center;
  background-size: contain;
}
dl.stats dd.hits::before {
  background: url("https://github.com/Ambra1720/lumu/blob/icon/hits.png") no-repeat center;
  background-size: contain;
}
dl.stats dd.collections::before {
  background: url("https://github.com/Ambra1720/lumu/blob/icon/collections.png") no-repeat center;
  background-size: contain;
}
dl.stats dd.subscriptions::before {
  background: url("https://github.com/Ambra1720/lumu/blob/icon/subscriptions.png") no-repeat center;
  background-size: contain;
}

/* ===== 标签分类标题（猫狗emoji） ===== */
ul.tags li.warnings:first-child:before {
  content: "⚠️🐱 Archive Warnings:" !important;
  background-image: none !important;
  padding-left: 0 !important;
}
li.warnings + li.relationships:before {
  content: "💕🐶 Relationships:" !important;
  background-image: none !important;
}
li.relationships + li.characters:before {
  content: "👤🐱 Characters:" !important;
  background-image: none !important;
}
li.characters + li.freeforms:before {
  content: "🏷️🐶 Additional Tags:" !important;
  background-image: none !important;
}

/* ===== 评级 / 分类图标 ===== */
.blurb ul.required-tags li .rating-general-audience {
  background-image: url("https://github.com/Ambra1720/lumu/blob/icon/G.png") !important;
}
.blurb ul.required-tags li .rating-teen {
  background-image: url("https://github.com/Ambra1720/lumu/blob/icon/T.png") !important;
}
.blurb ul.required-tags li .rating-mature {
  background-image: url("https://github.com/Ambra1720/lumu/blob/icon/M.png") !important;
}
.blurb ul.required-tags li .rating-explicit {
  background-image: url("https://github.com/Ambra1720/lumu/blob/icon/E.png") !important;
}
