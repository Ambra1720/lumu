/* ===== 书签隐私状态图标 ===== */
.status .rec {
  background-image: url("https://github.com/Ambra1720/lumu/blob/icon/rec-star.png") !important;
}
.status .public {
  background-image: url("https://github.com/Ambra1720/lumu/blob/icon/public.png") !important;
}
.status .private {
  background-image: url("https://github.com/Ambra1720/lumu/blob/icon/private-lock.png") !important;
}
.status .hidden {
  background-image: url("https://github.com/Ambra1720/lumu/blob/icon/hidden.png") !important;
}

/* ===== 分页箭头 ===== */
html body #main ol.pagination li.previous a {
  background-image: url("https://github.com/Ambra1720/lumu/blob/icon/prev.png") !important;
}
html body #main ol.pagination li.next a {
  background-image: url("https://github.com/Ambra1720/lumu/blob/icon/next.png") !important;
}

/* ===== 神秘头像 ===== */
.mystery.header.picture.module div.icon {
  background-image: url("https://github.com/Ambra1720/lumu/blob/icon/mystery.png") !important;
  background-size: contain;
}

/* ===== 作品摘要 & 注释标题 ===== */
.summary h3.heading::before {
  content: "🐶 ° ₊ ʚ Summary ɞ ₊ ° 🐱" !important;
}
.notes h3.heading::before {
  content: "🐶 ° ₊ ʚ Notes ɞ ₊ ° 🐱" !important;
}

/* ===== 作品页作者行装饰 ===== */
#workskin h3.byline::after {
  content: "♡ ⟡⋆.˚˚₊‧꒰ა ♱ ໒꒱ ‧₊˚⊹  ˖⟡♡" !important;
  background-image: none !important;
  width: auto !important;
  height: auto !important;
  font-size: 1rem;
  text-align: center;
  margin-top: 12px;
  color: var(--primary-pink);
}

/* ===== 标签悬停装饰 ===== */
#main .blurb a.tag:active::before,
#main .blurb a.tag:focus::before {
  content: "♡︎ " !important;
}
#main .blurb a.tag:active::after,
#main .blurb a.tag:focus::after {
  content: " ♡︎" !important;
}

/* ===== 下拉菜单等 ===== */
#greeting .menu, #header .menu {
  border-radius: 20px !important;
  background: var(--bg-modal) !important;
  border: 1px solid var(--primary-pink) !important;
}

/* ===== 输入框 ===== */
input, textarea, select {
  background: var(--bg-input) !important;
  border: 1px solid var(--primary-pink) !important;
  border-radius: 16px !important;
  box-shadow: inset 0 1px 3px rgba(0,0,0,0.02), 0 0 0 1px rgba(174,228,255,0.2) !important;
}
input:focus, textarea:focus {
  border-color: var(--primary-blue) !important;
  box-shadow: 0 0 0 3px rgba(174,228,255,0.25) !important;
}

/* ===== 顶部导航 ===== */
#header ul.primary li a {
  background: transparent !important;
  color: var(--text-main) !important;
  border-radius: 30px !important;
  padding: 5px 12px !important;
}
#header ul.primary li a:hover {
  background: var(--primary-pink) !important;
  color: #2c2c2c !important;
}

/* ===== 页码当前样式 ===== */
.pagination .current {
  background: var(--primary-blue) !important;
  color: #1a1a1a !important;
  border-radius: 30px !important;
}

/* ===== 滚动条 ===== */
* {
  scrollbar-width: thin;
  scrollbar-color: var(--primary-pink) var(--primary-blue);
}
::-webkit-scrollbar-thumb {
  background: var(--primary-pink);
  border-radius: 20px;
}
::-webkit-scrollbar-track {
  background: var(--primary-blue);
  border-radius: 20px;
}

/* ===== 页面水印彩蛋（猫狗） ===== */
body::after {
  content: "🐱₊⁺♡₊⁺🐶";
  position: fixed;
  bottom: 6px;
  right: 12px;
  font-size: 12px;
  opacity: 0.15;
  pointer-events: none;
  z-index: 9999;
  font-family: monospace;
}

#main .listbox, #dashboard .listbox,
#main fieldset.listbox, #dashboard fieldset.listbox {
  background: transparent !important;
}
.blurb ul.required-tags li .rating,
.blurb ul.required-tags li .category,
.blurb ul.required-tags li .warnings,
.blurb ul.required-tags li .iswip {
  filter: var(--icon-tint-main);
}

/* ===== 头像容器需为相对定位，以便伪元素叠加 ===== */
.home .primary.header.module .icon {
  position: relative !important;
  overflow: visible !important;  /* 让装饰框可以超出头像边界 */
}

/* ===== 头像外围装饰框 ===== */
.home .primary.header.module .icon::after {
  content: "" !important;
  display: block !important;
  position: absolute !important;
  left: 50% !important;
  top: 50% !important;
  width: 140px !important;
  height: 140px !important;
  margin-left: -70px !important;
  margin-top: -70px !important;
  background-image: url("https://github.com/Ambra1720/lumu/blob/icon/avatar-frame.png.png") !important;
  background-repeat: no-repeat !important;
  background-position: center !important;
  background-size: contain !important;
  z-index: 3 !important;
  pointer-events: none !important;
  border: none !important;
  box-shadow: none !important;
}

/* ----- 确保头像图片在框内正常显示（圆角） ----- */
.home .primary.header.module .icon img {
  display: block !important;
  width: 96px !important;
  height: 96px !important;
  border-radius: 50% !important;
  position: relative !important;
  z-index: 2 !important;
  border: 2px solid var(--primary-pink) !important;
  box-shadow: 0 0 0 4px rgba(174, 228, 255, 0.3) !important;
}

