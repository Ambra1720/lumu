  background-image: url("https://github.com/Ambra1720/lumu/blob/icon/MM.png") !important;
}
.blurb ul.required-tags li .category-femslash {
  background-image: url("https://github.com/Ambra1720/lumu/blob/icon/FF.png") !important;
}
.blurb ul.required-tags li .category-het {
  background-image: url("https://github.com/Ambra1720/lumu/blob/icon/FM.png") !important;
}
.blurb ul.required-tags li .category-multi {
  background-image: url("https://github.com/Ambra1720/lumu/blob/icon/Multi.png") !important;
}
